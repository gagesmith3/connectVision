# connectVision configuration template
# Copy this file to .env and update values for each Raspberry Pi unit.
# Do NOT commit .env to git.

# Machine assignment
MACHINE_ID=14
DEVICE_ID=

# Database
DB_HOST=192.168.1.6
DB_PORT=3306
DB_USER=webapp
DB_PASSWORD=CHANGE_ME
DB_NAME=iwt_db

# Web interface
WEB_PORT=8080

# Camera mode presets: 1080p30, 720p60, custom
CAMERA_MODE=720p60
# Camera index from libcamera list
CAMERA_INDEX=0

# Camera capture resolution (1080p default)
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
# Used for CAMERA_MODE=custom
CAMERA_FPS=30

# Focus controls
# AF_MODE: continuous, auto, manual, off
AF_MODE=continuous
# LENS_POSITION is used when AF_MODE=manual or off (example values: 0.0 to 10.0)
LENS_POSITION=
