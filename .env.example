# connectVision configuration template
# Copy this file to .env and update values for each Raspberry Pi unit.
# Do NOT commit .env to git.

# Machine assignment
MACHINE_ID=14
DEVICE_ID=

# Database
DB_HOST=192.168.1.6
DB_PORT=3306
DB_USER=webapp
DB_PASSWORD=CHANGE_ME
DB_NAME=iwt_db

# Web interface
WEB_PORT=8080

# Camera index from libcamera list (for multi-camera systems)
# Camera mode, AF mode, and lens position are now configured via the webapp dashboard
CAMERA_INDEX=0
